<?xml version="1.0"?>
<launch>
  <arg name="robot_ip" default="192.168.2.55" />
  <arg name="load_gripper" default="true" />
      <!-- 10.10.10.10 Athena -->
      <!-- 192.168.2.55 Poseidon -->

  <!-- Copied from franka_control.launch from panda_moveit_config package -->
  <include file="$(find panda_moveit_config)/launch/franka_control.launch" pass_all_args="true" />

  <!-- Calibration: a ZED + static TFs about poseidon -->
  <!-- <include file="$(find franka_zed_gazebo)/launch/zed2_eye2hand.launch" /> -->
  <!-- <include file="$(find franka_zed_gazebo)/launch/zed2_eye2hand_second.launch" /> -->
  <include file="$(find franka_zed_gazebo)/launch/zed2_eye2hand_two.launch" />

  <!-- For Flipping Task: Type the code below to load the cartesian impedance controller -->
  <!-- rosservice call /controller_manager/load_controller "name: 'cartesian_impedance_example_controller'" -->

</launch>